{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cgt-bandwidth/support-certificate.schema.json",
  "title": "SupportCertificate",
  "type": "object",
  "required": ["coordinate_universe", "passed", "results"],
  "properties": {
    "coordinate_universe": {"type": "array", "items": {"type": "string"}},
    "passed": {"type": "boolean"},
    "results": {"type": "array"},
    "bound_fallback": {"type": "boolean"},
    "fallback_coordinates": {"type": "array", "items": {"type": "string"}},
    "fallback_reasons": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
