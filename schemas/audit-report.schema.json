{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cgt-bandwidth/audit-report.schema.json",
  "title": "CGT Bandwidth Audit Report",
  "type": "object",
  "required": [
    "schema_version",
    "release_mode",
    "records",
    "completion",
    "completion_certificate",
    "completion_law_certificate",
    "support_product",
    "support_product_certificate",
    "release_graph",
    "release_action",
    "release_action_certificate"
  ],
  "properties": {
    "schema_version": {"const": "cgt-bandwidth.audit.v1"},
    "release_mode": {"enum": ["strict", "compatibility"]},
    "records": {"type": "object"},
    "completion": {"type": "object"},
    "completion_certificate": {"type": "object"},
    "completion_law_certificate": {"type": "object"},
    "support_product": {"type": "array"},
    "support_product_certificate": {"type": "object"},
    "support_exact": {"type": ["boolean", "null"]},
    "separation_coordinates": {"type": ["array", "null"]},
    "release_graph": {"type": "object"},
    "release_action": {"type": "object"},
    "release_action_certificate": {"type": "object"},
    "exact_support": {"type": "array"},
    "support_exact_certificate": {"type": "object"},
    "support_table_certificate": {"type": "object"},
    "support_signatures": {"type": "object"}
  },
  "additionalProperties": false
}
